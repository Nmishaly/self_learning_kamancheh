# Copy this file to .env for local development with `vercel dev`.
# In production, set these in the Vercel project settings instead.

# Required for the /api/annotate-notes endpoint (adds Hebrew technique cues to
# transcribed notes). Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. If set, the annotate endpoint requires an x-app-token header that
# matches this value, so the public URL can't be used to spend your API credits.
# APP_ACCESS_TOKEN=choose-a-long-random-string

# Optional. The matching token the browser sends. Set this to the SAME value as
# APP_ACCESS_TOKEN above when you enable the gate. (Exposed to the client at
# build time, so it deters casual abuse rather than being a true secret.)
# VITE_APP_ACCESS_TOKEN=choose-a-long-random-string

# ── Cloud storage for practice recordings (optional) ─────────────────────────
# Recordings always persist on-device (IndexedDB) so they survive a refresh with
# zero setup. To ALSO back them up to Vercel Blob (survives cache clears / new
# devices), connect a Blob store to the Vercel project — Vercel injects
# BLOB_READ_WRITE_TOKEN automatically (pull it locally with `vercel env pull`) —
# and opt the client in by setting the flag below to "true".
# VITE_ENABLE_BLOB=true
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx   # auto-set on Vercel; do not commit
